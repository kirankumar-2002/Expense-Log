<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme using AppCompat for biometric compatibility -->
    <style name="Theme.ExpenseLogPro" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.ExpenseLogPro.Splash" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/splash_bg</item>
        <item name="android:statusBarColor">@color/splash_bg</item>
    </style>
</resources>
